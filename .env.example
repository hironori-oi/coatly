# =====================================================================
# Coatly 環境変数テンプレ
# 本番では Vercel Environment Variables に登録する。
# ローカル開発は .env.local にコピーして埋める（.env.local は .gitignore）。
# =====================================================================

# ---- Turso (libSQL) -----------------------------------------------------
# `turso db create coatly` で作成 → `turso db show coatly --url` で取得
TURSO_DATABASE_URL=libsql://coatly-xxxxx.turso.io
# `turso db tokens create coatly` で発行
TURSO_AUTH_TOKEN=ey...

# ---- Better Auth --------------------------------------------------------
# 32 byte 以上のランダム文字列。`openssl rand -base64 32` で生成
BETTER_AUTH_SECRET=please-replace-me-with-32-bytes-random-string
# 本番は https://coatly.vercel.app, 開発は http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# ---- Cloudflare R2 ------------------------------------------------------
# Cloudflare ダッシュボード → R2 → "Manage R2 API Tokens" で発行
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=coatly-receipts

# ---- Resend (Email) -----------------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# DEC-032: 送信元はメインドメイン `improver.jp` 直
# Vercel 本番では実値を登録、ローカルは送信不要なら空でも OK（console fallback）
EMAIL_FROM=Coatly <noreply@improver.jp>
EMAIL_REPLY_TO=support@improver.jp

# ---- Vercel KV (Rate Limit) --------------------------------------------
# Phase 1 は optional（実装は P1 必須だが POC 段階では未接続でも build 可）
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---- Public ------------------------------------------------------------
# クライアントから見える URL のみ。秘密情報は絶対に NEXT_PUBLIC_ にしない
NEXT_PUBLIC_APP_URL=http://localhost:3000
