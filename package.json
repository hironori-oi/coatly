{
  "name": "coatly",
  "version": "0.1.0",
  "private": true,
  "description": "Coatly - テニス部 予算管理 Webアプリ（PRJ-015）",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-http-header-size=32768 next dev --turbo",
    "build": "next build",
    "start": "cross-env NODE_OPTIONS=--max-http-header-size=32768 next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file-if-exists=.env.local scripts/seed.ts",
    "db:seed:e2e": "tsx --env-file-if-exists=.env.local scripts/seed-e2e.ts",
    "db:seed:managers": "tsx --env-file-if-exists=.env.local scripts/seed-managers.ts",
    "db:cleanup-e2e": "tsx --env-file-if-exists=.env.local scripts/cleanup-e2e-users.ts",
    "email:dev": "email dev --dir src/emails --port 3001",
    "email:export": "email export --dir src/emails --out emails/build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@heroicons/react": "^2.2.0",
    "@libsql/client": "^0.14.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.12",
    "@sentry/nextjs": "^10.50.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "^0.5.1",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.460.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-day-picker": "9.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^3.0.0",
    "recharts": "^2.13.0",
    "resend": "^4.0.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^4.0.0",
    "ulid": "^2.3.0",
    "ulidx": "^2.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "drizzle-kit": "0.31.4",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
